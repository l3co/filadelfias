{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Filadelfias",
  "version": "0.1.0",
  "identifier": "com.filadelfias",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Filadelfias",
        "width": 390,
        "height": 844,
        "minWidth": 360,
        "minHeight": 640,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' http://localhost:8000 https://api.filadelfias.com; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEMyODFDRUQxOTYxMTFEM0QKUldROUhSR1cwYzZCd3FMaHFEMENMek9NdWJMaVBMRHczdnN6VC96Y2VQVUdGWUlJQzB2anlWdUMK",
      "endpoints": [
        "https://github.com/l3co/filadelfias/releases/latest/download/latest.json"
      ]
    }
  }
}
