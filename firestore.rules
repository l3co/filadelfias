rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // ============================================================================
    // HELPER FUNCTIONS
    // ============================================================================
    
    // Verifica se o usuário está autenticado
    function isAuthenticated() {
      return request.auth != null;
    }
    
    // Obtém o ID do usuário autenticado
    function userId() {
      return request.auth.uid;
    }
    
    // Verifica se o usuário é membro do tenant (tem membership)
    function isTenantMember(tenantId) {
      return isAuthenticated() && 
        exists(/databases/$(database)/documents/user_memberships/$(tenantId + '_' + userId()));
    }
    
    // Obtém o membership do usuário no tenant
    function getMembership(tenantId) {
      return get(/databases/$(database)/documents/user_memberships/$(tenantId + '_' + userId())).data;
    }
    
    // Obtém o membro vinculado ao usuário no tenant
    function getMember(tenantId) {
      let members = getAfter(/databases/$(database)/documents/tenants/$(tenantId)/members).data;
      return members[userId()];
    }
    
    // Verifica se é admin do sistema (role no membership)
    function isAdmin(tenantId) {
      return isTenantMember(tenantId) && getMembership(tenantId).role == 'ADMIN';
    }
    
    // Verifica se é moderador
    function isModerator(tenantId) {
      return isTenantMember(tenantId) && getMembership(tenantId).role in ['ADMIN', 'MODERATOR'];
    }
    
    // ============================================================================
    // PERMISSION FUNCTIONS (Manual Presbiteriano)
    // ============================================================================
    
    // Verifica se é Pastor
    function isPastor(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.office == 'PASTOR';
    }
    
    // Verifica se é Presbítero
    function isPresbitero(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.office == 'PRESBITERO';
    }
    
    // Verifica se é Diácono
    function isDiacono(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
        get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.office == 'DIACONO';
    }
    
    // Verifica se é liderança (Pastor ou Presbítero) - pode governar
    function isLeadership(tenantId) {
      return isPastor(tenantId) || isPresbitero(tenantId);
    }
    
    // Verifica se é oficial ordenado (Pastor, Presbítero ou Diácono)
    function isOfficer(tenantId) {
      return isPastor(tenantId) || isPresbitero(tenantId) || isDiacono(tenantId);
    }
    
    // Verifica se tem função de Tesoureiro
    function isTesoureiro(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
        'TESOUREIRO' in get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.functions;
    }
    
    // Verifica se tem função de Secretário
    function isSecretario(tenantId) {
      return exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
        'SECRETARIO' in get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.functions;
    }
    
    // ============================================================================
    // GLOBAL COLLECTIONS
    // ============================================================================
    
    // Users - apenas o próprio usuário pode ler/editar seus dados
    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }
    
    // User Memberships - usuário pode ler suas memberships
    match /user_memberships/{membershipId} {
      allow read: if isAuthenticated() && 
        resource.data.user_id == userId();
      allow create: if false; // Apenas backend pode criar
      allow update, delete: if false; // Apenas backend pode modificar
    }
    
    // Tenants - membros podem ler, apenas admin pode editar
    match /tenants/{tenantId} {
      allow read: if isTenantMember(tenantId);
      allow create: if isAuthenticated(); // Qualquer usuário pode criar igreja
      allow update: if isAdmin(tenantId) || isPastor(tenantId);
      allow delete: if isAdmin(tenantId);
      
      // ========================================================================
      // MEMBERS SUBCOLLECTION
      // Permissões: Pastor/Presbítero/Secretário podem editar
      // Diácono pode criar, Membro pode visualizar
      // ========================================================================
      match /members/{memberId} {
        // Todos os membros do tenant podem visualizar lista de membros
        allow read: if isTenantMember(tenantId);
        
        // Criar membro: Pastor, Presbítero, Diácono ou Secretário
        allow create: if isLeadership(tenantId) || isDiacono(tenantId) || isSecretario(tenantId);
        
        // Editar membro: Pastor, Presbítero ou Secretário
        allow update: if isLeadership(tenantId) || isSecretario(tenantId);
        
        // Deletar membro: apenas Pastor
        allow delete: if isPastor(tenantId);
      }
      
      // ========================================================================
      // GOVERNANCE SUBCOLLECTIONS
      // Permissões: Apenas Pastor e Presbítero podem gerenciar
      // Diácono pode visualizar
      // ========================================================================
      match /councils/{councilId} {
        // Visualizar: Pastor, Presbítero, Diácono
        allow read: if isOfficer(tenantId);
        
        // Criar/Editar: apenas liderança (Pastor, Presbítero)
        allow create, update: if isLeadership(tenantId);
        
        // Deletar: apenas Pastor ou Presbítero com manage
        allow delete: if isLeadership(tenantId);
      }
      
      // ========================================================================
      // FINANCIAL SUBCOLLECTIONS
      // Permissões: Tesoureiro tem acesso total
      // Pastor/Presbítero podem visualizar e criar
      // Diácono pode visualizar
      // ========================================================================
      match /financial_accounts/{accountId} {
        // Visualizar: Pastor, Presbítero, Diácono, Tesoureiro
        allow read: if isOfficer(tenantId) || isTesoureiro(tenantId);
        
        // Criar/Editar/Deletar: Pastor ou Tesoureiro
        allow create, update, delete: if isPastor(tenantId) || isTesoureiro(tenantId);
      }
      
      match /transactions/{transactionId} {
        // Visualizar: Pastor, Presbítero, Diácono, Tesoureiro
        allow read: if isOfficer(tenantId) || isTesoureiro(tenantId);
        
        // Criar: Pastor, Presbítero ou Tesoureiro
        allow create: if isLeadership(tenantId) || isTesoureiro(tenantId);
        
        // Editar/Deletar: Pastor ou Tesoureiro
        allow update, delete: if isPastor(tenantId) || isTesoureiro(tenantId);
      }
      
      match /transaction_categories/{categoryId} {
        // Visualizar: Pastor, Presbítero, Diácono, Tesoureiro
        allow read: if isOfficer(tenantId) || isTesoureiro(tenantId);
        
        // Gerenciar: Pastor ou Tesoureiro
        allow create, update, delete: if isPastor(tenantId) || isTesoureiro(tenantId);
      }
      
      // ========================================================================
      // EBD SUBCOLLECTIONS
      // Permissões: Todos os membros podem visualizar
      // Pastor/Presbítero podem gerenciar classes
      // Diácono pode criar lições e matricular alunos
      // ========================================================================
      match /ebd_classes/{classId} {
        // Visualizar: todos os membros
        allow read: if isTenantMember(tenantId);
        
        // Criar/Editar: Pastor, Presbítero
        allow create, update: if isLeadership(tenantId);
        
        // Deletar: apenas Pastor
        allow delete: if isPastor(tenantId);
      }
      
      match /ebd_students/{studentId} {
        // Visualizar: todos os membros
        allow read: if isTenantMember(tenantId);
        
        // Criar (matricular): Pastor, Presbítero, Diácono
        allow create: if isOfficer(tenantId);
        
        // Editar/Deletar: Pastor, Presbítero
        allow update, delete: if isLeadership(tenantId);
      }
      
      match /ebd_lessons/{lessonId} {
        // Visualizar: todos os membros
        allow read: if isTenantMember(tenantId);
        
        // Criar: Pastor, Presbítero, Diácono
        allow create: if isOfficer(tenantId);
        
        // Editar/Deletar: Pastor, Presbítero
        allow update, delete: if isLeadership(tenantId);
      }
      
      // ========================================================================
      // MISSIONS SUBCOLLECTIONS
      // Permissões: Todos os membros podem visualizar
      // Pastor/Presbítero e Evangelista/Missionário podem criar
      // ========================================================================
      match /missionaries/{missionaryId} {
        // Visualizar: todos os membros
        allow read: if isTenantMember(tenantId);
        
        // Criar: Pastor, Presbítero, ou membro com função de Evangelista/Missionário
        allow create: if isLeadership(tenantId) || 
          (exists(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())) &&
           ('EVANGELISTA' in get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.functions ||
            'MISSIONARIO' in get(/databases/$(database)/documents/tenants/$(tenantId)/members/$(userId())).data.functions));
        
        // Editar: Pastor, Presbítero
        allow update: if isLeadership(tenantId);
        
        // Deletar: apenas Pastor
        allow delete: if isPastor(tenantId);
      }
      
      // ========================================================================
      // EVENTS SUBCOLLECTION (futuro)
      // ========================================================================
      match /events/{eventId} {
        allow read: if isTenantMember(tenantId);
        allow create: if isOfficer(tenantId);
        allow update: if isLeadership(tenantId);
        allow delete: if isPastor(tenantId);
      }
    }
    
    // ============================================================================
    // GLOBAL MEETINGS COLLECTION (referencia council_id)
    // ============================================================================
    match /meetings/{meetingId} {
      // Para meetings, precisamos verificar o tenant através do council
      // Por simplicidade, apenas usuários autenticados com acesso ao council podem acessar
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated(); // Backend valida permissões
      allow delete: if isAuthenticated(); // Backend valida permissões
    }
  }
}
