FROM node:20-alpine

WORKDIR /app

# Build argument for API URL (Vite needs it at build time)
ARG VITE_API_URL=http://localhost:8000
ENV VITE_API_URL=$VITE_API_URL

# Install dependencies
COPY package*.json ./
RUN npm ci

# Copy source code
COPY . .

# Build application with the API URL
RUN npm run build

# Expose port
EXPOSE 5173

# Start preview server
CMD ["npm", "run", "preview", "--", "--port", "5173", "--host"]
